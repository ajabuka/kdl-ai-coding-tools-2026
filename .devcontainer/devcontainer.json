// DH & RSE Summer School 2026: Working Critically with AI Coding Tools
// Author: Mary Chester-Kadwell
// Repository: https://github.com/DH-RSE-Summer-School/kdl-ai-coding-tools-2026

{
  "name": "Working Critically with AI Coding Tools",
  "image": "mcr.microsoft.com/devcontainers/python:3.13",
  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "lts" }
  },
  "remoteEnv": {
    "OPENROUTER_API_KEY": "${localEnv:OPENROUTER_API_KEY}",
    "LLM7_API_KEY": "${localEnv:LLM7_API_KEY}"
  },
  "postCreateCommand": "cp -n .continue/.env.example .continue/.env && npm install -g opencode-ai @anthropic-ai/claude-code && pip install -r requirements.txt",
  "customizations": {
    "vscode": {
      "extensions": [
        "continue.continue",
        "anthropic.claude-code",
        "saoudrizwan.claude-dev",
        "sst-dev.opencode",
        "ms-toolsai.jupyter"
      ]
    }
  }
}
